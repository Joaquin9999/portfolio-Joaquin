---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPortfolioData } from '../lib/ctftime';

const writeupModules = import.meta.glob('./writeups/*.md', { eager: true });
const localWriteups = Object.entries(writeupModules)
  .map(([path, module]) => {
    const slug = path.split('/').pop()?.replace(/\.md$/, '') ?? '';
    const frontmatter = (module as any).frontmatter ?? {};

    return {
      title: frontmatter.title || slug.replaceAll('-', ' '),
      description: frontmatter.description || 'Writeup tecnico.',
      url: `/writeups/${slug}`,
      tag: frontmatter.tag || 'Writeup',
      date: frontmatter.date || '',
    };
  })
  .sort((a, b) => {
    if (!a.date && !b.date) return a.title.localeCompare(b.title);
    if (!a.date) return 1;
    if (!b.date) return -1;
    return String(b.date).localeCompare(String(a.date));
  });

const writeupsGitbooks = [...localWriteups];

const proyectos = [
  {
    id: 'aulanexa-web-lab',
    title: 'AulaNexa: rastros en el portal legado',
    summary: 'Reto CTF web educativo de SQL Injection para reconstruir un incidente en un portal academico legado.',
    description:
      'AulaNexa es una plataforma CTF web educativa enfocada en SQL Injection, donde el participante debe resolver un incidente por fases encadenadas en un portal academico legado. El reto avanza por rutas clave (/login, /directory, /courses, /reports), cada una con evidencias y objetivos tecnicos hasta completar la cadena final. Esta pensada para practica guiada en entornos controlados. Demo publica: https://aulanexa-web.vercel.app',
    tags: ['Python', 'Flask', 'SQLite', 'PostgreSQL', 'Supabase', 'Jinja', 'HTML5', 'CSS3'],
    github: 'https://github.com/Joaquin9999/AulaNexa-LaboratorioDeWeb-Public',
    demo: 'https://aulanexa-web.vercel.app',
    status: 'Completado',
  },
  {
    id: 'bluebox-platform',
    title: 'BlueBox: laboratorio defensivo y analisis de incidentes',
    summary: 'Plataforma tecnica para practicar forense, deteccion y respuesta en escenarios realistas de ciberseguridad.',
    description:
      'BlueBox es un entorno tecnico orientado a Blue Team para entrenamiento practico en investigacion y respuesta a incidentes. El proyecto organiza escenarios con telemetria, artefactos y trazas para que el participante reconstruya lineas de tiempo, identifique evidencias y documente hallazgos accionables. Incluye enfoque en metodologia defensiva, validacion de hipotesis y comunicacion tecnica de resultados, manteniendo una experiencia reproducible para practica continua.',
    tags: ['Python', 'Linux', 'Sigma', 'YARA', 'Suricata', 'Bash'],
    github: 'https://github.com/Joaquin9999/BlueBox',
    status: 'Completado',
  },
  {
    id: 'security-labs',
    title: 'Security Labs & Challenge Authoring',
    summary: 'Retos tecnicos para formacion y evaluacion de habilidades.',
    description:
      'Creacion de laboratorios con pasos de reproduccion, evidencia e impacto para fortalecer analisis tecnico y documentacion profesional.',
    tags: ['Python', 'Linux', 'Burp Suite', 'Wireshark', 'Nmap'],
    github: '#',
    status: 'Proximamente',
    upcoming: true,
  },
];

const experiencias = [
  {
    role: 'Founder & Leader - CTF-UPB (Cybersecurity Club)',
    when: 'Jun 2025 - Actualidad',
    bullets: [
      'Lidero entrenamientos, charlas y talleres de seguridad con continuidad del equipo.',
      'Diseno y creo retos CTF para Linux, redes, web, forense y criptografia.',
    ],
  },
  {
    role: 'Founder & Captain - Ch0wn3rs (CTF Team)',
    when: 'Jun 2025 - Actualidad',
    bullets: [
      'Coordino estrategia, preparacion competitiva y distribucion de categorias.',
      'Participacion activa en CTFs internacionales con ranking top de Colombia.',
    ],
  },
  {
    role: 'Teaching Assistant - Information Security (UPB)',
