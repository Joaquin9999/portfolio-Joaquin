  <div class="project-modal" id="project-modal" hidden>
    <button class="project-modal-backdrop" aria-label="Cerrar popup" data-project-close></button>
    <article class="project-modal-card" role="dialog" aria-modal="true" aria-labelledby="project-modal-title">
      <button class="project-modal-close" aria-label="Cerrar popup" data-project-close>✕</button>
      <p class="writeup-tag">Ficha de proyecto</p>
      <h3 id="project-modal-title"></h3>
      <p id="project-modal-description"></p>
      <div class="tag-row" id="project-modal-tags"></div>
      <div class="modal-action-row">
        <a class="btn-mini" id="project-modal-github" href="#" target="_blank" rel="noreferrer">Ir a GitHub</a>
        <a class="btn-mini btn-mini-alt" id="project-modal-demo" href="#" target="_blank" rel="noreferrer" hidden>Ver demo</a>
      </div>
    </article>
  </div>

  <script is:inline>
    const TEAM_ID = 408704;
    const FETCH_TIMEOUT_MS = 5000;
    const normalizeTeamName = (name) => String(name || '').toLowerCase().replace(/[^a-z0-9]/g, '');
    const getTeamScore = (scores, teamId, aliasesSet) => {
      const byId = scores.find((s) => Number(s?.team_id) === teamId);
      if (byId) return byId;
      return scores.find((s) => aliasesSet.has(normalizeTeamName(s?.team_name)));
    };

    async function fetchJson(url, timeoutMs = FETCH_TIMEOUT_MS) {
      const controller = new AbortController();
      const timeout = setTimeout(() => controller.abort(), timeoutMs);

      try {
        const response = await fetch(url, { signal: controller.signal });
        if (!response.ok) throw new Error(`Request failed: ${response.status}`);
        return response.json();
      } finally {
        clearTimeout(timeout);
      }
    }

    function renderBestResults(best) {
      const container = document.getElementById('best-results-list');
      if (!container || !Array.isArray(best) || best.length === 0) return;

      container.innerHTML = best
        .map(
          (ctf) => `
              <article class="result-card">
                <div>
                  <p class="result-title">${ctf.title}</p>
                </div>
                <div class="result-pill">#${ctf.place}</div>
                <a href="${ctf.url}" target="_blank" rel="noreferrer">Ver evento</a>
              </article>
            `
        )
        .join('');
    }

    async function refreshBestResults() {
      try {
        const todayKey = new Date().toISOString().slice(0, 10);
        const cacheKey = `ctf-best-results-${todayKey}`;
        const cached = sessionStorage.getItem(cacheKey);
        if (cached) {
          try {
            const parsed = JSON.parse(cached);
            renderBestResults(parsed);
            return;
          } catch {
            sessionStorage.removeItem(cacheKey);
          }
        }

        const currentYear = new Date().getUTCFullYear();
        const [team, yearResults, prevResults] = await Promise.all([
          fetchJson(`https://ctftime.org/api/v1/teams/${TEAM_ID}/`),
          fetchJson(`https://ctftime.org/api/v1/results/${currentYear}/`),
          fetchJson(`https://ctftime.org/api/v1/results/${currentYear - 1}/`),
        ]);

        const yearBucket = team?.rating?.[String(currentYear)] || {};
        const globalRankEl = document.getElementById('global-rank');
        const countryRankEl = document.getElementById('country-rank');
        const ratingEl = document.getElementById('rating-points');
        if (globalRankEl && yearBucket.rating_place) globalRankEl.textContent = `#${yearBucket.rating_place}`;
        if (countryRankEl && yearBucket.country_place) countryRankEl.textContent = `#${yearBucket.country_place}`;
        if (ratingEl && yearBucket.rating_points) ratingEl.textContent = Number(yearBucket.rating_points).toFixed(2);

        const allDatasets = [yearResults, prevResults];
        const candidates = [];
        const aliases = [team?.name, team?.primary_alias, ...(team?.aliases || [])]
          .map((entry) => String(entry || '').trim())
          .filter(Boolean);
        const aliasesSet = new Set(aliases.map((entry) => normalizeTeamName(entry)));

        for (const dataset of allDatasets) {
          for (const [eventId, eventData] of Object.entries(dataset)) {
            const scores = Array.isArray(eventData?.scores) ? eventData.scores : [];
            const score = getTeamScore(scores, TEAM_ID, aliasesSet);
            if (!score) continue;
            candidates.push({
              eventId: Number(eventId),
              title: eventData.title,
              place: Number(score.place),
              points: score.points,
            });
          }
        }

        candidates.sort((a, b) => a.place - b.place || b.eventId - a.eventId);
        const topCandidateBatch = candidates.slice(0, 8);

        const eventsMeta = await Promise.all(
          topCandidateBatch.map(async (entry) => {
            try {
              const meta = await fetchJson(`https://ctftime.org/api/v1/events/${entry.eventId}/`);
              return {
                ...entry,
                title: meta.title || entry.title,
                finish: meta.finish,
                url: meta.ctftime_url || `https://ctftime.org/event/${entry.eventId}/`,
              };
            } catch {
              return {
                ...entry,
                finish: undefined,
                url: `https://ctftime.org/event/${entry.eventId}/`,
              };
            }
          })
        );

        eventsMeta.sort((a, b) => a.place - b.place || Date.parse(b.finish || 0) - Date.parse(a.finish || 0));
        const best = eventsMeta.slice(0, 8);

        if (!best.length) return;
        renderBestResults(best);
        sessionStorage.setItem(cacheKey, JSON.stringify(best));
      } catch {
        // keep server-rendered fallback
      }
    }

    function setupProjectModal() {
      const modal = document.getElementById('project-modal');
      if (!modal) return;

      const titleEl = document.getElementById('project-modal-title');
      const descriptionEl = document.getElementById('project-modal-description');
      const tagsEl = document.getElementById('project-modal-tags');
      const githubEl = document.getElementById('project-modal-github');
      const demoEl = document.getElementById('project-modal-demo');
      const toolIconMap = {
        linux: 'https://cdn.simpleicons.org/linux/ffffff',
        python: 'https://cdn.simpleicons.org/python/ffffff',
        bash: 'https://cdn.simpleicons.org/gnubash/ffffff',
        wireshark: 'https://cdn.simpleicons.org/wireshark/ffffff',
        'burp suite': 'https://cdn.simpleicons.org/burpsuite/ffffff',
        ctftime: 'https://cdn.simpleicons.org/ctftime/ffffff',
        'azure devops': 'https://cdn.simpleicons.org/azuredevops/ffffff',
        nmap: '',
        splunk: 'https://cdn.simpleicons.org/splunk/ffffff',
        html5: 'https://cdn.simpleicons.org/html5/ffffff',
        css3: 'https://cdn.simpleicons.org/css/ffffff',
        javascript: 'https://cdn.simpleicons.org/javascript/ffffff',
        github: 'https://cdn.simpleicons.org/github/ffffff',
        flask: 'https://cdn.simpleicons.org/flask/ffffff',
        sqlite: 'https://cdn.simpleicons.org/sqlite/ffffff',
        postgresql: 'https://cdn.simpleicons.org/postgresql/ffffff',
        supabase: 'https://cdn.simpleicons.org/supabase/ffffff',
        jinja: '',
      };

      const closeModal = () => modal.setAttribute('hidden', '');

      const escapeHtml = (input) =>
        input
          .replaceAll('&', '&amp;')
          .replaceAll('<', '&lt;')
          .replaceAll('>', '&gt;')
          .replaceAll('"', '&quot;')
          .replaceAll("'", '&#39;');

      const linkifyUrls = (input) =>
        escapeHtml(input).replace(
          /(https?:\/\/[^\s]+)/g,
          '<a href="$1" target="_blank" rel="noreferrer">$1</a>'
        );

      document.querySelectorAll('[data-project-open]').forEach((openBtn) => {
        openBtn.addEventListener('click', () => {
          const title = openBtn.getAttribute('data-project-title') || 'Proyecto';
          const description = openBtn.getAttribute('data-project-description') || '';
          const tags = (openBtn.getAttribute('data-project-tags') || '')
            .split('|')
            .filter(Boolean);
          const github = openBtn.getAttribute('data-project-github') || '#';
          const demo = openBtn.getAttribute('data-project-demo') || '';

          if (titleEl) titleEl.textContent = title;
          if (descriptionEl) descriptionEl.innerHTML = linkifyUrls(description);
          if (githubEl) githubEl.setAttribute('href', github);
          if (demoEl) {
            if (demo) {
              demoEl.setAttribute('href', demo);
              demoEl.removeAttribute('hidden');
            } else {
              demoEl.setAttribute('hidden', '');
            }
          }
          if (tagsEl) {
            tagsEl.innerHTML = tags
              .map((tag) => {
                const icon = toolIconMap[tag.toLowerCase()] || '';
                return `
                  <span class="tool-tag">
                    ${icon ? `<img src="${icon}" alt="" loading="lazy" />` : '<span class="tool-dot" aria-hidden="true"></span>'}
                    ${tag}
                  </span>
                `;
              })
              .join('');
          }

          modal.removeAttribute('hidden');
        });
      });

      document.querySelectorAll('[data-project-close]').forEach((closeBtn) => {
        closeBtn.addEventListener('click', closeModal);
      });

      window.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && !modal.hasAttribute('hidden')) {
          closeModal();
        }
      });
    }

    const runWhenIdle = (callback) => {
      if ('requestIdleCallback' in window) {
        window.requestIdleCallback(callback, { timeout: 1500 });
      } else {
        setTimeout(callback, 300);
      }
    };

    window.addEventListener('load', () => runWhenIdle(refreshBestResults), { once: true });
    setupProjectModal();
    setupMobileNavbar();
    setupSmartNavbar();

    function setupMobileNavbar() {
      const nav = document.querySelector('[data-mobile-nav]');
      const toggle = nav?.querySelector('.mobile-nav-toggle');
      if (!nav || !toggle) return;

      const close = () => {
        nav.classList.remove('is-open');
        toggle.setAttribute('aria-expanded', 'false');
      };

      const open = () => {
        nav.classList.add('is-open');
        toggle.setAttribute('aria-expanded', 'true');
      };

      toggle.addEventListener('click', () => {
        const isOpen = nav.classList.contains('is-open');
        if (isOpen) close();
        else open();
      });

      nav.querySelectorAll('.links a').forEach((anchor) => {
        anchor.addEventListener('click', close);
      });

      window.addEventListener('resize', () => {
        if (window.innerWidth > 768) close();
      });
    }

    function setupSmartNavbar() {
      const nav = document.querySelector('.topbar-sticky');
      if (!nav) return;

      let hideTimer;
      let lastY = window.scrollY;

      const showNav = () => nav.classList.remove('nav-hidden');
      const scheduleHide = (delay = 850) => {
        clearTimeout(hideTimer);
        if (window.scrollY < 120) {
          nav.classList.remove('nav-hidden');
          return;
        }
        hideTimer = window.setTimeout(() => {
          nav.classList.add('nav-hidden');
        }, delay);
      };

      window.addEventListener(
        'scroll',
        () => {
          const y = window.scrollY;
          if (Math.abs(y - lastY) < 2) return;
          showNav();
          scheduleHide(700);
          lastY = y;
        },
        { passive: true }
      );

      nav.querySelectorAll('a[href^="#"]').forEach((link) => {
        link.addEventListener('click', () => {
          showNav();
          scheduleHide(1300);
        });
      });

      scheduleHide(1300);
    }

    function setupHeroAvatar() {
      const wrapper = document.getElementById('hero-avatar');
      const heroPanel = wrapper?.closest('.hero-variant-console');
      const avatarCol = wrapper?.closest('.console-left');
      const primary = wrapper?.querySelector('.avatar-primary');
      if (!wrapper || !primary) return;

      let hoverLocked = false;
      let switchTimeout;
      let settleTimeout;

      const setState = (className, on) => {
        wrapper.classList.toggle(className, on);
        heroPanel?.classList.toggle(className, on);
        avatarCol?.classList.toggle(className, on);
      };

      const clearTimers = () => {
        if (switchTimeout) clearTimeout(switchTimeout);
        if (settleTimeout) clearTimeout(settleTimeout);
        switchTimeout = undefined;
        settleTimeout = undefined;
      };

      primary.addEventListener('error', () => {
        setState('primary-missing', true);
        clearTimers();
      });

      const scheduleNextGlitch = (delay = 1000) => {
        if (wrapper.classList.contains('primary-missing') || hoverLocked) return;
        clearTimeout(switchTimeout);
        switchTimeout = window.setTimeout(() => {
          setState('is-switching', true);
          settleTimeout = window.setTimeout(() => {
            setState('is-switching', false);
            const next = 2200 + Math.floor(Math.random() * 1400);
            scheduleNextGlitch(next);
          }, 720);
        }, delay);
      };

      wrapper.addEventListener('mouseenter', () => {
        hoverLocked = true;
        setState('is-switching', false);
        setState('is-hovered', true);
        clearTimers();
      });

      wrapper.addEventListener('mouseleave', () => {
        hoverLocked = false;
        setState('is-hovered', false);
        scheduleNextGlitch(350);
      });

      scheduleNextGlitch(900);
    }

    setupHeroAvatar();

  </script>
</BaseLayout>
