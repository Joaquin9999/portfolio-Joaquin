      'Creation of labs with reproducible steps, evidence, and impact-oriented reporting to strengthen technical analysis and professional documentation.',
    tags: ['Python', 'Linux', 'Burp Suite', 'Wireshark', 'Nmap'],
    github: '#',
    status: 'Coming Soon',
    upcoming: true,
  },
];

const experiencias = [
  {
    role: 'Founder & Leader - CTF-UPB (Cybersecurity Club)',
    when: 'Jun 2025 - Present',
    bullets: [
      'Lead recurring security trainings, talks, and workshops.',
      'Design and build CTF challenges for Linux, networking, web, forensics, and crypto.',
    ],
  },
  {
    role: 'Founder & Captain - Ch0wn3rs (CTF Team)',
    when: 'Jun 2025 - Present',
    bullets: [
      'Coordinate strategy, competition preparation, and category distribution.',
