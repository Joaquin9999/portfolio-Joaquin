    </section>

    <section class="section writeups-shell" id="writeups">
      <div class="section-head">
        <h2>Writeups</h2>
      </div>
      <div class="writeups-krauq-grid">
        {writeupsGitbooks.map((item, idx) => (
          <a
            class="writeup-entry"
            href={item.urlEn}
            data-writeup-es={item.urlEs}
            data-writeup-en={item.urlEn}
            target={item.url.startsWith('http') ? '_blank' : undefined}
            rel="noreferrer"
