      <div class="links" id="site-links">
        <a href="#ranking">CTFs</a>
        <a href="#writeups">Writeups</a>
        <a href="#proyectos">Projects</a>
        <a href="#experiencia">Experience</a>
        <a href="#contacto">Contact</a>
      </div>
      <div class="lang-switch" aria-label="Language switch">
        <a class="lang-btn" href="/">ES</a>
        <a class="lang-btn is-active" href="/en/" aria-current="page">EN</a>
      </div>
    </nav>

    <header class="hero" id="top">
      <div class="hero-variants">
        <article class="hero-variant hero-variant-console is-active">
          <div class="console-left">
            <div class="hero-image-frame hero-image-frame-square avatar-glitch" id="hero-avatar">
              <img
                src={heroPrimaryPhoto}
                srcset={`${heroPrimaryPhoto} 360w, ${heroPrimaryPhotoLarge} 640w`}
                sizes="(max-width: 768px) 68vw, 286px"
                alt="Joaquin Castano Trujillo"
                loading="eager"
                decoding="async"
                fetchpriority="high"
                width="360"
                height="360"
                class="avatar-layer avatar-primary"
              />
              <img
                src={heroNeyiPhoto}
                alt=""
                loading="eager"
                decoding="async"
                width="360"
                height="360"
                class="avatar-layer avatar-neyi"
              />
              <span class="avatar-scan" aria-hidden="true"></span>
            </div>
            <p class="avatar-hover-hint">Hover me</p>
          </div>
          <div class="console-right">
            <h1 class="hero-name-inline hero-name-glitch">
              <span class="name-main name-joaquin">Joaquin Castaño Trujillo</span>
              <span class="name-main name-neyi">Neyi21</span>
