      <div class="skills-tag-grid">
        {skillTags.map((skill) => (
          <span class="skill-chip">
            {skill.icon ? (
              <>
                <img
                  src={skill.icon}
                  alt={`${skill.name} icon`}
                  loading="lazy"
                  onerror="this.style.display='none'; this.nextElementSibling.style.display='inline-block';"
                />
                <span class="skill-dot skill-dot-fallback" aria-hidden="true"></span>
              </>
            ) : (
              <span class="skill-dot" aria-hidden="true"></span>
            )}
            {skill.name}
          </span>
        ))}
      </div>
    </section>

    <footer class="footer" id="contacto">
      <h2>Contact</h2>
      <div class="contact-grid">
        {contacts.map((c) => (
          <a class="contact-card" href={c.href} target={c.href.startsWith('mailto:') ? undefined : '_blank'} rel="noreferrer">
            <span class={`contact-icon contact-${c.icon}`}>
              {c.icon === 'github' && (
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path
                    fill="currentColor"
                    d="M12 .5a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2.2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.3-1.8-1.3-1.8-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1.1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.7-.3-5.5-1.3-5.5-5.9 0-1.3.5-2.3 1.2-3.2-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.2 1.2a11 11 0 0 1 5.8 0c2.2-1.5 3.2-1.2 3.2-1.2.6 1.6.2 2.8.1 3.1.8.9 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1 .8 2.1v3.1c0 .3.2.7.8.6A12 12 0 0 0 12 .5Z"
                  />
                </svg>
              )}
              {c.icon === 'linkedin' && (
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path
                    fill="currentColor"
                    d="M4.98 3.5C4.98 4.88 3.87 6 2.5 6A2.5 2.5 0 0 1 0 3.5 2.5 2.5 0 0 1 2.5 1 2.5 2.5 0 0 1 4.98 3.5ZM.4 8h4.2v15.6H.4V8Zm7.2 0h4v2.1h.1c.6-1.1 2-2.3 4.1-2.3 4.4 0 5.2 2.9 5.2 6.6v9.2h-4.2v-8.2c0-2-.1-4.5-2.7-4.5-2.7 0-3.1 2.1-3.1 4.3v8.4H7.6V8Z"
                  />
                </svg>
              )}
              {c.icon === 'ctf' && (
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path fill="currentColor" d="M4 2h2v20H4V2Zm4 2h11l-2.5 3L19 10H8V4Z" />
                </svg>
              )}
              {c.icon === 'mail' && (
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path
                    fill="currentColor"
                    d="M3 5h18a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1Zm0 2v.5l9 5.4 9-5.4V7H3Zm18 10V9.8l-8.5 5.1a1 1 0 0 1-1 0L3 9.8V17h18Z"
                  />
                </svg>
              )}
            </span>
            <div>
              <p>{c.label}</p>
              <span>{c.value}</span>
            </div>
          </a>
        ))}
      </div>
    </footer>
  </main>

  <div class="project-modal" id="project-modal" hidden>
    <button class="project-modal-backdrop" aria-label="Cerrar popup" data-project-close></button>
    <article class="project-modal-card" role="dialog" aria-modal="true" aria-labelledby="project-modal-title">
      <button class="project-modal-close" aria-label="Cerrar popup" data-project-close>✕</button>
      <p class="writeup-tag">Ficha de proyecto</p>
      <h3 id="project-modal-title"></h3>
      <p id="project-modal-description"></p>
      <div class="tag-row" id="project-modal-tags"></div>
      <div class="modal-action-row">
        <a class="btn-mini" id="project-modal-github" href="#" target="_blank" rel="noreferrer">Ir a GitHub</a>
        <a class="btn-mini btn-mini-alt" id="project-modal-demo" href="#" target="_blank" rel="noreferrer" hidden>Ver demo</a>
      </div>
    </article>
  </div>

  <script is:inline>
    function setupProjectModal() {
      const modal = document.getElementById('project-modal');
      if (!modal) return;

      const titleEl = document.getElementById('project-modal-title');
      const descriptionEl = document.getElementById('project-modal-description');
      const tagsEl = document.getElementById('project-modal-tags');
      const githubEl = document.getElementById('project-modal-github');
      const demoEl = document.getElementById('project-modal-demo');
      const toolIconMap = {
        linux: '/icons/skills/linux.svg',
        python: '/icons/skills/python.svg',
        bash: '/icons/skills/gnubash.svg',
        wireshark: '/icons/skills/wireshark.svg',
        'burp suite': '/icons/skills/burpsuite.svg',
        ctftime: 'https://cdn.simpleicons.org/ctftime/ffffff',
        'azure devops': '',
        nmap: '',
        splunk: '/icons/skills/splunk.svg',
        html5: 'https://cdn.simpleicons.org/html5/ffffff',
        css3: 'https://cdn.simpleicons.org/css/ffffff',
        javascript: 'https://cdn.simpleicons.org/javascript/ffffff',
        github: 'https://cdn.simpleicons.org/github/ffffff',
        flask: 'https://cdn.simpleicons.org/flask/ffffff',
        sqlite: 'https://cdn.simpleicons.org/sqlite/ffffff',
        postgresql: 'https://cdn.simpleicons.org/postgresql/ffffff',
        supabase: 'https://cdn.simpleicons.org/supabase/ffffff',
        jinja: '',
      };

      const closeModal = () => modal.setAttribute('hidden', '');

      const escapeHtml = (input) =>
        input
          .replaceAll('&', '&amp;')
          .replaceAll('<', '&lt;')
          .replaceAll('>', '&gt;')
          .replaceAll('"', '&quot;')
          .replaceAll("'", '&#39;');

      const linkifyUrls = (input) =>
        escapeHtml(input).replace(
          /(https?:\/\/[^\s]+)/g,
          '<a href="$1" target="_blank" rel="noreferrer">$1</a>'
        );

      document.querySelectorAll('[data-project-open]').forEach((openBtn) => {
        openBtn.addEventListener('click', () => {
          const title = openBtn.getAttribute('data-project-title') || 'Project';
          const description = openBtn.getAttribute('data-project-description') || '';
          const tags = (openBtn.getAttribute('data-project-tags') || '')
            .split('|')
            .filter(Boolean);
          const github = openBtn.getAttribute('data-project-github') || '#';
          const demo = openBtn.getAttribute('data-project-demo') || '';

          if (titleEl) titleEl.textContent = title;
          if (descriptionEl) descriptionEl.innerHTML = linkifyUrls(description);
          if (githubEl) githubEl.setAttribute('href', github);
          if (demoEl) {
            if (demo) {
              demoEl.setAttribute('href', demo);
              demoEl.removeAttribute('hidden');
            } else {
              demoEl.setAttribute('hidden', '');
            }
          }
          if (tagsEl) {
            tagsEl.innerHTML = tags
              .map((tag) => {
                const icon = toolIconMap[tag.toLowerCase()] || '';
                return `
                  <span class="tool-tag">
                    ${icon ? `<img src="${icon}" alt="" loading="lazy" />` : '<span class="tool-dot" aria-hidden="true"></span>'}
                    ${tag}
                  </span>
                `;
              })
              .join('');
          }

          modal.removeAttribute('hidden');
        });
      });

      document.querySelectorAll('[data-project-close]').forEach((closeBtn) => {
        closeBtn.addEventListener('click', closeModal);
      });

      window.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && !modal.hasAttribute('hidden')) {
          closeModal();
        }
      });
    }

    setupProjectModal();
    setupMobileNavbar();
    setupSmartNavbar();

    function setupMobileNavbar() {
      const nav = document.querySelector('[data-mobile-nav]');
      const toggle = nav?.querySelector('.mobile-nav-toggle');
      if (!nav || !toggle) return;

      const close = () => {
        nav.classList.remove('is-open');
        toggle.setAttribute('aria-expanded', 'false');
      };

      const open = () => {
        nav.classList.add('is-open');
        toggle.setAttribute('aria-expanded', 'true');
      };

      toggle.addEventListener('click', () => {
        const isOpen = nav.classList.contains('is-open');
        if (isOpen) close();
        else open();
      });

      nav.querySelectorAll('.links a').forEach((anchor) => {
        anchor.addEventListener('click', close);
      });

      window.addEventListener('resize', () => {
        if (window.innerWidth > 768) close();
      });
    }

    function setupSmartNavbar() {
      const nav = document.querySelector('.topbar-sticky');
      if (!nav) return;

      let hideTimer;
      let lastY = window.scrollY;

      const showNav = () => nav.classList.remove('nav-hidden');
      const scheduleHide = (delay = 850) => {
        clearTimeout(hideTimer);
        if (window.scrollY < 120) {
          nav.classList.remove('nav-hidden');
          return;
        }
        hideTimer = window.setTimeout(() => {
          nav.classList.add('nav-hidden');
        }, delay);
      };

      window.addEventListener(
        'scroll',
        () => {
          const y = window.scrollY;
          if (Math.abs(y - lastY) < 2) return;
          showNav();
          scheduleHide(700);
          lastY = y;
        },
        { passive: true }
      );

      nav.querySelectorAll('a[href^="#"]').forEach((link) => {
        link.addEventListener('click', () => {
          showNav();
          scheduleHide(1300);
        });
      });

      scheduleHide(1300);
    }

    function setupHeroAvatar() {
      const wrapper = document.getElementById('hero-avatar');
      const heroPanel = wrapper?.closest('.hero-variant-console');
      const avatarCol = wrapper?.closest('.console-left');
      const primary = wrapper?.querySelector('.avatar-primary');
      if (!wrapper || !primary) return;

      let hoverLocked = false;
      let switchTimeout;
      let settleTimeout;

      const setState = (className, on) => {
        wrapper.classList.toggle(className, on);
        heroPanel?.classList.toggle(className, on);
        avatarCol?.classList.toggle(className, on);
      };

      const clearTimers = () => {
        if (switchTimeout) clearTimeout(switchTimeout);
        if (settleTimeout) clearTimeout(settleTimeout);
        switchTimeout = undefined;
        settleTimeout = undefined;
      };

      primary.addEventListener('error', () => {
        setState('primary-missing', true);
        clearTimers();
      });

      const scheduleNextGlitch = (delay = 1000) => {
        if (wrapper.classList.contains('primary-missing') || hoverLocked) return;
        clearTimeout(switchTimeout);
        switchTimeout = window.setTimeout(() => {
          setState('is-switching', true);
          settleTimeout = window.setTimeout(() => {
            setState('is-switching', false);
            const next = 2200 + Math.floor(Math.random() * 1400);
            scheduleNextGlitch(next);
          }, 720);
        }, delay);
      };

      wrapper.addEventListener('mouseenter', () => {
        hoverLocked = true;
        setState('is-switching', false);
        setState('is-hovered', true);
        clearTimers();
      });

      wrapper.addEventListener('mouseleave', () => {
        hoverLocked = false;
        setState('is-hovered', false);
        scheduleNextGlitch(350);
      });

      scheduleNextGlitch(900);
    }

    setupHeroAvatar();
    setupLiveCtfTimeRefresh();

    async function setupLiveCtfTimeRefresh() {
      try {
        const response = await fetch(`/api/ctftime?t=${Date.now()}`, { cache: 'no-store' });
        if (!response.ok) return;
        const data = await response.json();
        const teamData = data?.team;
        const competitions = Array.isArray(data?.recentCompetitions) ? data.recentCompetitions : [];

        if (teamData) {
          const countryRankEl = document.getElementById('country-rank');
          const globalRankEl = document.getElementById('global-rank');
          const ratingPointsEl = document.getElementById('rating-points');
          const countryYearEl = document.getElementById('country-year');
          const globalYearEl = document.getElementById('global-year');

          const year = Number(teamData.year);
          const countryRank = Number(teamData.countryRank);
          const globalRank = Number(teamData.globalRank);
          const ratingPoints = Number(teamData.ratingPoints);

          if (countryRankEl && Number.isFinite(countryRank)) countryRankEl.textContent = `#${countryRank}`;
          if (globalRankEl && Number.isFinite(globalRank)) globalRankEl.textContent = `#${globalRank}`;
          if (ratingPointsEl && Number.isFinite(ratingPoints)) ratingPointsEl.textContent = ratingPoints.toFixed(2);
          if (countryYearEl && Number.isFinite(year)) countryYearEl.textContent = String(year);
          if (globalYearEl && Number.isFinite(year)) globalYearEl.textContent = String(year);
        }

        if (competitions.length > 0) {
          const resultsRoot = document.getElementById('best-results-list');
          if (!resultsRoot) return;
          resultsRoot.innerHTML = '';

          for (const ctf of competitions) {
            const article = document.createElement('article');
            article.className = 'result-card';

            const left = document.createElement('div');
            const title = document.createElement('p');
            title.className = 'result-title';
            title.textContent = String(ctf?.title || 'CTF Event');
            left.appendChild(title);

            const place = document.createElement('div');
            place.className = 'result-pill';
            place.textContent = `#${Number(ctf?.place) || '-'}`;

            const link = document.createElement('a');
            link.href = String(ctf?.ctftimeUrl || 'https://ctftime.org/');
            link.target = '_blank';
            link.rel = 'noreferrer';
            link.textContent = 'View event';

            article.appendChild(left);
            article.appendChild(place);
            article.appendChild(link);
            resultsRoot.appendChild(article);
          }
        }
      } catch {
        // Keep server-rendered snapshot on any runtime failure.
      }
    }

  </script>
</BaseLayout>
