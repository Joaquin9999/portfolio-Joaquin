  canonical="https://neyi.me/"
  image="/images/neyi-pixel.jpg"
  structuredData={structuredData}
>
  <main class="page-wrap">
    <nav class="topbar topbar-sticky" data-mobile-nav>
      <a href="#top" class="brand">
        <span>Neyi21</span>
      </a>
      <button class="mobile-nav-toggle" type="button" aria-expanded="false" aria-controls="site-links">
        Menu
