  { name: 'Splunk', icon: '/icons/skills/splunk.svg' },
  { name: 'Sigma', icon: '' },
  { name: 'YARA', icon: '' },
  { name: 'Suricata', icon: '' },
  { name: 'Snork', icon: '' },
  { name: 'Linux', icon: '/icons/skills/linux.svg' },
  { name: 'Bash', icon: '/icons/skills/gnubash.svg' },
  { name: 'Python', icon: '/icons/skills/python.svg' },
  { name: 'Burp Suite', icon: '/icons/skills/burpsuite.svg' },
  { name: 'Wireshark', icon: '/icons/skills/wireshark.svg' },
  { name: 'Figma', icon: '/icons/skills/figma.svg' },
