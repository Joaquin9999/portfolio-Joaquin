---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPortfolioData } from '../lib/ctftime';

const writeupModules = import.meta.glob('./writeups/*.md', { eager: true });
const localWriteups = Object.entries(writeupModules).map(([path, module]) => {
  const slug = path.split('/').pop()?.replace(/\.md$/, '') ?? '';
  const frontmatter = (module as any).frontmatter ?? {};
  const isEn = slug.endsWith('-en');
  const baseSlug = isEn ? slug.slice(0, -3) : slug;

  return {
    slug,
    baseSlug,
    isEn,
    title: frontmatter.title || slug.replaceAll('-', ' '),
    description: frontmatter.description || 'Technical writeup.',
    tag: frontmatter.tag || 'Writeup',
    date: frontmatter.date || '',
  };
});

const writeupsByBase = new Map<string, { es?: (typeof localWriteups)[number]; en?: (typeof localWriteups)[number] }>();

for (const entry of localWriteups) {
  const row = writeupsByBase.get(entry.baseSlug) ?? {};
  if (entry.isEn) row.en = entry;
  else row.es = entry;
  writeupsByBase.set(entry.baseSlug, row);
}

const writeupsGitbooks = Array.from(writeupsByBase.entries())
  .map(([baseSlug, versions]) => {
    const preferred = versions.en ?? versions.es;
    if (!preferred) return null;
    return {
      title: preferred.title,
      description: preferred.description,
      tag: preferred.tag,
      date: preferred.date,
      url: `/writeups/${baseSlug}`,
      urlEs: versions.es ? `/writeups/${versions.es.slug}` : `/writeups/${baseSlug}`,
      urlEn: versions.en ? `/writeups/${versions.en.slug}` : (versions.es ? `/writeups/${versions.es.slug}` : `/writeups/${baseSlug}`),
    };
  })
  .filter(Boolean)
  .sort((a, b) => {
    if (!a?.date && !b?.date) return String(a?.title).localeCompare(String(b?.title));
    if (!a?.date) return 1;
    if (!b?.date) return -1;
    return String(b.date).localeCompare(String(a.date));
  }) as Array<{
    title: string;
    description: string;
    tag: string;
    date: string;
    url: string;
    urlEs: string;
    urlEn: string;
  }>;

const proyectos = [
  {
    id: 'aulanexa-web-lab',
    title: 'AulaNexa: Traces in the Legacy Portal',
    summary: 'Educational web CTF focused on SQL Injection to reconstruct an incident in a legacy academic portal.',
    description:
      'AulaNexa is an educational web CTF platform focused on SQL Injection, where the participant solves an incident through chained phases in a legacy academic portal. The challenge progresses across key routes (/login, /directory, /courses, /reports), each with evidence and technical goals until the full chain is completed. Built for guided practice in controlled environments. Public demo: https://aulanexa-web.vercel.app',
    tags: ['Python', 'Flask', 'SQLite', 'PostgreSQL', 'Supabase', 'Jinja', 'HTML5', 'CSS3'],
    github: 'https://github.com/Joaquin9999/AulaNexa-LaboratorioDeWeb-Public',
    demo: 'https://aulanexa-web.vercel.app',
    status: 'Completed',
  },
  {
    id: 'bluebox-platform',
    title: 'BlueBox CLI: Blue Team CTF Workspace',
    summary: 'CLI for CTFs (forensics/Blue Team) that organizes reproducible cases, prepares environments, and optimizes LLM-assisted workflows.',
    description:
      'BlueBox is a CLI built for CTF workflows, especially forensics and Blue Team tasks. It helps organize cases reproducibly, prepare a defensive tooling environment, and keep the workspace ready for efficient LLM-assisted analysis. Its goal is to reduce operational friction and token waste.',
    tags: ['Python', 'Linux', 'Bash', 'LLM Ops'],
    github: 'https://github.com/Joaquin9999/BlueBox',
    status: 'Completed',
  },
  {
    id: 'security-labs',
