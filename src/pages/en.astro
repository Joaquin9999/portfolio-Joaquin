const heroPrimaryPhoto = '/images/joaquin-real-square-360.jpg';
const heroPrimaryPhotoLarge = '/images/joaquin-real-square-640.jpg';
const heroNeyiPhoto = '/images/neyi21-360.jpg';
const seoKeywords = 'Neyi, Neyi21, Joaquin Castaño, Joaquin Castano, Ch0wn3rs, CTF, CTFtime, ciberseguridad, writeups, seguridad informatica, forense digital, blue team';
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Joaquin Castaño Trujillo',
    alternateName: ['Neyi21', 'Joaquin Castano Trujillo'],
    url: 'https://neyi.me',
    image: 'https://neyi.me/images/neyi-pixel.jpg',
    jobTitle: 'Junior Security Engineer / Security Analyst',
    knowsAbout: [
      'Cybersecurity',
      'CTF',
      'Digital Forensics',
      'Blue Team',
      'Incident Response',
      'MITRE ATT&CK',
    ],
    sameAs: [
      'https://github.com/Joaquin9999',
      'https://www.linkedin.com/in/joaquin-casta%C3%B1o-trujillo-00422126a/',
      'https://ctftime.org/team/408704',
