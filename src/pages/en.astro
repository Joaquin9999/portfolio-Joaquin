                </>
              )}
            </div>
            {project.upcoming && <div class="project-soon-overlay">Coming Soon</div>}
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="experiencia">
      <div class="section-head">
        <h2>Experience</h2>
      </div>
