        ))}
      </div>
    </section>

    <section class="section" id="proyectos">
      <div class="section-head">
        <h2>Projects</h2>
      </div>
      <div class="cards-grid projects-grid">
        {proyectos.map((project, idx) => (
          <article class={`info-card project-card ${project.upcoming ? 'is-upcoming' : ''}`}>
            <div class="project-status-row">
              <p class="project-kicker">Project {String(idx + 1).padStart(2, '0')}</p>
              <span class={`project-state ${project.status.toLowerCase().includes('completed') ? 'is-completed' : ''}`}>{project.status}</span>
            </div>
            <h3>{project.title}</h3>
            <p>{project.summary}</p>
            <div class="project-actions">
              {project.upcoming ? (
                <>
                  <span class="btn-mini is-disabled" aria-disabled="true">GitHub</span>
                  <span class="btn-mini btn-mini-alt is-disabled" aria-disabled="true">View details</span>
                </>
              ) : (
                <>
                  <a class="btn-mini" href={project.github} target="_blank" rel="noreferrer">GitHub</a>
                  <button
                    class="btn-mini btn-mini-alt"
                    data-project-open
                    data-project-title={project.title}
                    data-project-description={project.description}
                    data-project-tags={project.tags.join('|')}
                    data-project-github={project.github}
                    data-project-demo={project.demo ?? ''}
