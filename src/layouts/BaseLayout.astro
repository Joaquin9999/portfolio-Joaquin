---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  canonical?: string;
  image?: string;
  noindex?: boolean;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = 'Joaquin Castano Trujillo | Security Portfolio',
  description = 'Portfolio de Joaquin Castano Trujillo (Neyi21), Security Engineer y CTF player de Ch0wn3rs.',
  keywords = 'Neyi, Neyi21, Joaquin Castano, Joaquin Castaño, Ch0wn3rs, CTF, cybersecurity, writeups, portfolio',
  canonical,
  image = '/images/neyi-pixel.jpg',
  noindex = false,
  structuredData,
} = Astro.props;

const url = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).toString();
const canonicalUrl = canonical ?? url;
const imageUrl = image.startsWith('http')
  ? image
  : new URL(image, Astro.site ?? Astro.url.origin).toString();
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="Joaquin Castaño Trujillo (Neyi21)" />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <meta name="googlebot" content={noindex ? 'noindex, nofollow' : 'index, follow, max-snippet:-1, max-image-preview:large'} />
    <meta name="theme-color" content="#0a0f1a" />
    <meta property="og:locale" content="es_CO" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:site_name" content="Neyi21 Portfolio" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@Neyi21" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <title>{title}</title>
    <link rel="dns-prefetch" href="//cdn.simpleicons.org" />
    {structuredData && (
      <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    )}
  </head>
  <body>
    <slot />
  </body>
</html>
